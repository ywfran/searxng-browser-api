# ── Server ────────────────────────────────────────────────────────────────────
PORT=3030
NODE_ENV=development
LOG_LEVEL=info

# ── Browser pool ──────────────────────────────────────────────────────────────
# Number of simultaneous Playwright BrowserContexts (~100 MB RAM each).
# Requests beyond this limit queue instead of crashing.
MAX_CONTEXTS=8

# ── Search orchestration ──────────────────────────────────────────────────────
# Navigation timeout per instance per request (ms).
SEARCH_TIMEOUT_MS=12000

# How long to wait for a round to return any result before launching
# reinforcement instances (ms). Lower = faster fallback, more context usage.
SEARCH_STAGGER_MS=5000

# After the first result arrives, how long to collect competing candidates
# before picking the winner (ms).
SEARCH_DECISION_WINDOW_MS=500

# ── Instance list ──────────────────────────────────────────────────────────────
# Hours between automatic instance list refreshes from searx.space.
INSTANCE_REFRESH_INTERVAL_HOURS=6

# Minimum monthly uptime % an instance must have to be included in the pool.
INSTANCE_MIN_UPTIME=80

# ── Chromium ──────────────────────────────────────────────────────────────────
# Path to Chromium binary. Leave commented to use Playwright's own download.
# In Docker: /usr/bin/chromium
# CHROME_PATH=/usr/bin/chromium

# Set to 1 in Docker to use the system Chromium instead of downloading one.
# PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
